NODE_ENV=development
LOG_LEVEL=debug

# Execution mode — "paper" simulates trades (safe default); "live" places real orders
EXECUTION_MODE=paper

# Bot's own wallet address — required for live balance checks; unused in paper mode
# BOT_WALLET=0xYourWalletAddressHere

# ── Live execution (required when EXECUTION_MODE=live) ────────────────────────
# Private key of the bot's trading wallet (0x-prefixed hex, 64 chars after 0x)
# NEVER commit this value. Keep it in a secrets manager / vault in production.
# PRIVATE_KEY=0xabc123...

# Polygon JSON-RPC endpoint (used for on-chain USDC balance reads)
# Defaults to the public Polygon RPC if omitted.
# RPC_URL=https://polygon-rpc.com

# Polymarket CLOB API key credentials (Level 2 auth — faster than on-chain signing)
# Obtain by running: client.createOrDeriveApiKey() once with your private key
# CLOB_API_KEY=your-api-key
# CLOB_SECRET=your-api-secret
# CLOB_PASSPHRASE=your-api-passphrase

# Maximum price slippage allowed vs. current mid-market price (percent, default 1)
# MAX_SLIPPAGE_PCT=1

# PostgreSQL — Phase 2
POSTGRES_URL=postgresql://localhost:5432/polymarketbot

# Redis — Phase 2
REDIS_URL=redis://localhost:6379

# Telegram — Phase 3
# Get token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=8708671592:AAG2aSBRoY0OOLnighIbyVxcBT_rP8_hTCU


# Comma-separated Telegram user IDs allowed to control the bot
# Find your ID by messaging @userinfobot on Telegram
ALLOWED_USER_IDS=123456789,987654321
